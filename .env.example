# ─── Server ───────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017/livestreaming
REDIS_URL=redis://127.0.0.1:6379

# ─── Authentication ───────────────────────────────────
JWT_SECRET=your_jwt_secret_here
SESSION_SECRET=your_session_secret_here

# ─── Cloudinary (Media Storage) ───────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Agora (Live Streaming) ───────────────────────────
AGORA_APP_ID=your_agora_app_id
PRIMARY_CERTIFICATE=your_agora_certificate

# ─── Games backend (adda-games-backend) ───────────────
# Shared HMAC secret. MUST equal PROVIDER_SECRET on the games backend.
# Without it every /internal/* route replies 403 INTERNAL_AUTH_DISABLED.
INTERNAL_SERVICE_SECRET=your_internal_service_secret_here

# Secret used to sign the short-lived player tokens the games backend verifies.
# MUST equal JWT_ACCESS_SECRET on the games backend.
# Keep it DIFFERENT from JWT_SECRET above — sharing that one would hand the games
# backend the key to every Adda session, admin sessions included.
GAME_JWT_ACCESS_SECRET=your_game_jwt_access_secret_here

# Lifetime of a game session token. Games defaults to 15 min; keep them in step.
GAME_SESSION_TOKEN_TTL_SECONDS=900

# Reject signed requests whose clock is further off than this. Must be >= the
# games backend's PROVIDER_CLOCK_SKEW_SECONDS.
INTERNAL_CLOCK_SKEW_SECONDS=300

# Require an HMAC signature on /internal/*. Leave true. Set to "false" ONLY during
# a cutover, to also accept the legacy static x-internal-secret header.
INTERNAL_REQUIRE_SIGNATURE=true

# Optional: pin the caller. Must match the games backend's PROVIDER_OPERATOR_ID.
# Leave unset to accept any operator id.
# GAMES_OPERATOR_ID=zimolive

# Outbound: the games backend's API base — MUST include its /api/v1 prefix.
# Used for reconciliation (GET /api/admin/game/reconciliation).
GAMES_BASE_URL=http://localhost:5002/api/v1
GAMES_TIMEOUT_MS=10000

# Optional: handed to the app in the session-token response so the client knows
# where to point the game.
# GAMES_PUBLIC_URL=http://localhost:5002

# ─── Feature Flags ────────────────────────────────────
XP_MODE=0              # Set to "1" to enable XP leveling

# ─── CORS (documented in README) ──────────────────────
# ALLOWED_ORIGINS=http://localhost:3004,https://admin.example.com


# ── Player auth (SHARED secret with the HOST backend) ─────────────────────────
# Player access tokens are signed by the host backend with JWT_ACCESS_SECRET and
# validated here locally. This is the only auth secret shared with the host.
JWT_ACCESS_SECRET=change_me_user_access_secret_at_least_32_chars_long